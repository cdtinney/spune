{
  "name": "spune-monorepo",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "Colin Tinney",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf node_modules packages/client/node_modules packages/server/node_modules pnpm-lock.yaml",
    "client:build": "pnpm --filter spune-client build",
    "client:lint": "pnpm --filter spune-client lint",
    "client:test": "pnpm --filter spune-client test",
    "client:test:coverage": "pnpm --filter spune-client test:coverage",
    "client:watch": "pnpm --filter spune-client watch",
    "dev": "docker compose -f docker-compose.dev.yml up -d && pnpm watch",
    "dev:stop": "docker compose -f docker-compose.dev.yml down",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm client:lint && pnpm server:lint",
    "server:build": "pnpm --filter spune-server build",
    "server:lint": "pnpm --filter spune-server lint",
    "server:start": "pnpm --filter spune-server start",
    "server:test": "pnpm --filter spune-server test",
    "server:test:coverage": "pnpm --filter spune-server test:coverage",
    "server:watch": "pnpm --filter spune-server watch",
    "start": "pnpm watch",
    "test": "pnpm -r test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:docker": "docker run --rm -e CI=true -v $(pwd):/work -w /work --network host mcr.microsoft.com/playwright:v1.59.1-noble bash -c 'npm i -g pnpm@10 && npx playwright test'",
    "test:e2e:update-snapshots": "docker run --rm -e CI=true -v $(pwd):/work -w /work --network host mcr.microsoft.com/playwright:v1.59.1-noble bash -c 'npm i -g pnpm@10 && npx playwright test --update-snapshots'",
    "watch": "concurrently --kill-others \"pnpm server:watch\" \"pnpm client:watch\""
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2"
  }
}
