{
  "name": "spune-monorepo",
  "version": "0.0.0",
  "private": true,
  "keywords": [],
  "author": "Colin Tinney",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "rm -rf node_modules packages/client/node_modules packages/server/node_modules package-lock.json",
    "client:build": "npm run build -w packages/client",
    "client:test": "npm run test -w packages/client",
    "client:test:coverage": "npm run test:coverage -w packages/client",
    "client:watch": "npm run watch -w packages/client",
    "server:lint": "npm run lint -w packages/server",
    "server:start": "npm run start -w packages/server",
    "server:test": "npm run test -w packages/server",
    "server:test:coverage": "npm run test:coverage -w packages/server",
    "server:test:integration": "npm run test:integration -w packages/server",
    "server:watch": "npm run watch -w packages/server",
    "start": "npm run server:start",
    "test": "npm run test:coverage --workspaces --if-present",
    "watch": "concurrently --kill-others \"npm run server:watch\" \"npm run client:watch\""
  },
  "devDependencies": {
    "concurrently": "^4.1.0"
  }
}
