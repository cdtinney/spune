    "watch": "nodemon app.js"
  },
  "dependencies": {
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "axios": "^1.15.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "passport": "^0.7.0",
    "passport-oauth2-refresh": "^2.2.0",
    "passport-spotify": "^1.0.1",
    "pg": "^8.20.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
