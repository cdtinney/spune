{
  "name": "spune-server",
  "version": "0.1.0",
  "description": "Spune back-end.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cdtinney/spune.git"
  },
  "author": "Colin Tinney",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/cdtinney/spune/issues"
  },
  "homepage": "https://github.com/cdtinney/spune#readme",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
